{
  "csharp": {
    "command": "node",
    "args": [
      "${CLAUDE_PLUGIN_ROOT}/proxy/index.js",
      "--server", "roslyn-language-server",
      "--",
      "--stdio",
      "--logLevel", "Information"
    ],
    "transport": "stdio",
    "extensionToLanguage": {
      ".cs": "csharp",
      ".csx": "csharp",
      ".razor": "razor",
      ".cshtml": "razor"
    },
    "startupTimeout": 120000,
    "maxRestarts": 3
  }
}
